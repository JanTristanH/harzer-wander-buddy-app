{
  "expo": {
    "name": "Harzer Wanderbuddy",
    "slug": "harzer-wander-buddy-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "harzerwanderbuddyapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "config": {
        "usesNonExemptEncryption": false
      },
      "bundleIdentifier": "de.kuestenbit.harzer-wander-buddy",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Harzer Wanderbuddy verwendet deinen Standort fuer Karte, Entfernungen und nahe Parkplaetze.",
        "NSPhotoLibraryUsageDescription": "Harzer Wanderbuddy benoetigt Zugriff auf deine Fotos, damit du ein Profilbild auswaehlen kannst.",
        "NSPhotoLibraryAddUsageDescription": "Harzer Wanderbuddy benoetigt Zugriff auf deine Fotos, falls du ein bearbeitetes Profilbild speichern moechtest."
      }
    },
    "android": {
      "package": "de.kuestenbit.harzerwanderbuddy",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Harzer Wanderbuddy verwendet deinen Standort fuer Karte, Entfernungen und nahe Parkplaetze."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Harzer Wanderbuddy benoetigt Zugriff auf deine Fotos, damit du ein Profilbild auswaehlen kannst."
        }
      ],
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "backendUrl": "http://192.168.2.188:4004",
      "auth0Domain": "dev-ijucl08spdudaszc.us.auth0.com",
      "auth0ClientId": "Pf0WY4b3Q2yu6CllOGaZC4RIlolcd4xh",
      "auth0Audience": "https://app.harzer-wander-buddy.de/api/v2/",
      "auth0Scope": "openid profile email offline_access",
      "auth0LogoutReturnPath": "auth/logout",
      "router": {},
      "eas": {
        "projectId": "1511f3e0-0255-4c5b-97a4-43e285483bc2"
      }
    }
  }
}
